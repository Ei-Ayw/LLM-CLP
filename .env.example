# LLM-CLP Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control!

# =====================================================
# API Keys (Required for counterfactual generation)
# =====================================================
ZHIPU_API_KEY=your_zhipu_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# =====================================================
# HuggingFace Token (Optional, for gated models)
# =====================================================
HF_TOKEN=your_huggingface_token_here

# =====================================================
# Paths (Override defaults if needed)
# =====================================================
# DATA_DIR=/path/to/data
# MODEL_CACHE_DIR=/path/to/model_cache